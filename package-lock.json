{
  "name": "d3hr",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "d3hr",
      "version": "0.0.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/api": {
      "name": "@d3hr/api",
      "version": "0.0.0",
      "dependencies": {
        "@d3hr/audit": "0.0.0",
        "@d3hr/policy": "0.0.0"
      }
    },
    "apps/web": {
      "name": "@d3hr/web",
      "version": "0.0.0"
    },
    "node_modules/@d3hr/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@d3hr/audit": {
      "resolved": "packages/audit",
      "link": true
    },
    "node_modules/@d3hr/policy": {
      "resolved": "packages/policy",
      "link": true
    },
    "node_modules/@d3hr/shared-types": {
      "resolved": "packages/shared-types",
      "link": true
    },
    "node_modules/@d3hr/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/audit": {
      "name": "@d3hr/audit",
      "version": "0.0.0",
      "dependencies": {
        "@d3hr/shared-types": "0.0.0"
      }
    },
    "packages/policy": {
      "name": "@d3hr/policy",
      "version": "0.0.0",
      "dependencies": {
        "@d3hr/shared-types": "0.0.0"
      }
    },
    "packages/shared-types": {
      "name": "@d3hr/shared-types",
      "version": "0.0.0"
    }
  }
}
